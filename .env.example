# ── LiteLLM proxy ──
LITELLM_URL=https://litellm.conneskills.com
LITELLM_API_KEY=sk-agent-specific-key

# ── Dynamic mode (Registry) ──
AGENT_ID=uuid-from-registry
REGISTRY_URL=https://cs-agent-registry-api-mqznmwfbgq-uc.a.run.app

# ── Agent service ──
AGENT_PORT=9100

# ── Prompt Management & Tracing (Phoenix) ──
PHOENIX_URL=https://phoenix-mqznmwfbgq-uc.a.run.app
PHOENIX_ENDPOINT=https://phoenix-mqznmwfbgq-uc.a.run.app
PHOENIX_API_KEY=tu-phoenix-api-key
PHOENIX_PROMPT_NAME=eo-agent-researcher
PHOENIX_PROMPT_TAG=production
