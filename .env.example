# ==============================================================================
# CS-AGENT-SERVICE (ADK) - CONFIGURATION
# ==============================================================================

# ── Identity (Injected by ai-platform-api during deployment) ──
AGENT_ID=uuid-from-registry
AGENT_PORT=9100

# ── Service Discovery ──
# URL of the Agent Registry API to fetch runtime configuration
REGISTRY_URL=http://agent-registry-api:9500

# ── LiteLLM Proxy ──
# URL of the LiteLLM Gateway
LITELLM_URL=https://litellm.conneskills.com
# The agent uses its own key provided by the platform
LITELLM_API_KEY=sk-agent-specific-key

# ── Prompt Management (Phoenix) ──
# URL of the Arize Phoenix API for dynamic prompt resolution
PHOENIX_URL=https://phoenix-1016644011094.us-central1.run.app
PHOENIX_API_KEY=tu-api-key-aqui

# ── Auth Note ──
# This service communicates with the Registry and Phoenix WITHOUT internal 
# authentication headers, relying on network-level trust.
